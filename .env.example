# --- Telegram ---
# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=123456789:AA-replace-with-real-token

# --- LLM ---
# Любой OpenAI-совместимый провайдер: OpenAI, OpenRouter, Together, локальный Ollama и т.д.
# Если ключ не задан — бот всё равно работает, но без AI-анализа (использует только rule-based scoring).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Database ---
# По умолчанию SQLite в файле bot.db рядом с проектом
DATABASE_URL=sqlite+aiosqlite:///bot.db

# --- Logging ---
LOG_LEVEL=INFO
